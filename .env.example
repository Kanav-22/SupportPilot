# Copy to .env and fill in one provider for local runs.

# Groq development run
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI final measured run
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Runtime defaults
LLM_PROVIDER=groq
CONFIDENCE_THRESHOLD=0.70
DB_PATH=db/supportpilot.db
